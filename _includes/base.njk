<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ description }}">
    <title>{{ title }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com/">
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700&family=Barlow+Condensed:wght@700&family=Oswald:wght@600;700&family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/js/menu.js" defer></script>
</head>
<body>
{# ===== HERO HEADER (shared across all pages) ===== #}
<div class="hero-header">
    <div class="top-bar">
        <button class="hamburger" id="menuToggle" aria-label="Otvori meni" aria-expanded="false" aria-controls="navDrawer" type="button">
            <span></span><span></span><span></span>
        </button>
        <a class="top-button" href="#kalkulator"><span class="top-button-icon">🧮</span>Zakažite online</a>
        <a class="top-button" href="/cenovnik.html"><span class="top-button-icon">💰</span>Pogledaj cene</a>
    </div>
    <div class="nav-overlay" id="navOverlay"></div>
    <nav class="nav-drawer" id="navDrawer" aria-hidden="true">
        <button class="nav-close" id="navClose" aria-label="Zatvori meni" type="button">×</button>
        <a href="/#usluge"><span class="nav-icon">📦</span>Usluge</a>
        <a href="/#cenovnik"><span class="nav-icon">💰</span>Cenovnik</a>
        <a href="/#kalkulator"><span class="nav-icon">🧮</span>Kalkulator</a>
        <a href="/odnosenje-starog-namestaja.html"><span class="nav-icon">🗑️</span>Odnošenje starog nameštaja</a>
        <a href="/prevoz-namestaja.html"><span class="nav-icon">🚚</span>Prevoz nameštaja</a>
        <a href="/#onama"><span class="nav-icon">ℹ️</span>O nama</a>
        <a href="tel:+381659410699"><span class="nav-icon">📞</span>Pozovite nas</a>
    </nav>
    <div class="hero-glow-line"></div>
    <div class="hero-logo"><span class="move">Move</span><span class="expert">Expert</span></div>
    {% if heroHeading %}
        <h1 style="text-align:center;font-size:1px;opacity:0;height:0;overflow:hidden;">{{ heroHeading }}</h1>
    {% endif %}
    {% if heroSubtitle %}
        <div class="hero-subtitle">{{ heroSubtitle }}</div>
    {% endif %}
    <div class="hero-mini-cards">
        <div class="hero-mini-card"><span class="hero-mini-icon">⭐</span><span>Besplatna procena</span></div>
        <div class="hero-mini-card"><span class="hero-mini-icon">🕒</span><span>Dostupni 00–24h</span></div>
    </div>
</div>

{{ content | safe }}

</body>
</html>
